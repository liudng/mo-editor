# Default: auto line endings, LF on checkout
* text=auto eol=lf

# Binary assets
*.png  binary
*.jpg  binary
*.jpeg binary
*.ico  binary
*.icns binary
*.qm   binary

# Text assets with explicit LF
*.svg      text eol=lf
*.qrc      text eol=lf
*.ui       text eol=lf
*.ts       text eol=lf
*.qss      text eol=lf
*.desktop  text eol=lf
*.xml      text eol=lf

# Source files
*.cpp   text eol=lf
*.hpp   text eol=lf
*.h     text eol=lf
*.cmake text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.sh    text eol=lf

# License files
LICENSE*  text eol=lf
*.txt     text eol=lf

# Git machinery
.gitignore  text eol=lf
.gitattributes text eol=lf
