# Git pre-commit hook: verify that staged C++ sources pass clang-format.

set -euo pipefail

if ! command -v clang-format >/dev/null 2>&1; then
    echo "clang-format not found; skipping format check." >&2
    exit 0
fi

staged_files=$(git diff --cached --name-only --diff-filter=ACM -- 'src/*.cpp' 'src/*.cc' 'src/*.cxx' 'src/*.hpp' 'src/*.h' 'tests/*.cpp' 'tests/*.hpp')

if [[ -z "${staged_files}" ]]; then
    exit 0
fi

failed=0
while IFS= read -r file; do
    if [[ -z "${file}" ]]; then
        continue
    fi
    if ! clang-format --dry-run -Werror "${file}" >/dev/null 2>&1; then
        echo "clang-format check failed: ${file}" >&2
        echo "  fix with: clang-format -i ${file}" >&2
        failed=1
    fi
done <<< "${staged_files}"

if [[ ${failed} -ne 0 ]]; then
    echo "Pre-commit hook: one or more staged files are not clang-format clean." >&2
    exit 1
fi

exit 0
