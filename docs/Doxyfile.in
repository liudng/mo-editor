# Doxyfile template for the Mo Qt6 text editor.
# SPDX-FileCopyrightText: 2026 Liu Dong <liudng@hotmail.com>
# SPDX-License-Identifier: GPL-3.0-or-later
#
# CMake will configure @PROJECT_VERSION@, @CMAKE_SOURCE_DIR@ and
# @CMAKE_BINARY_DIR@ at configure time and write the result to the build tree.

PROJECT_NAME           = "Mo"
PROJECT_NUMBER         = @PROJECT_VERSION@
PROJECT_BRIEF          = "A simple Qt6 text editor"
PROJECT_LOGO           =

INPUT                  = @CMAKE_SOURCE_DIR@/src \
                         @CMAKE_SOURCE_DIR@/docs
INPUT_ENCODING         = UTF-8
FILE_PATTERNS          = *.cpp \
                         *.hpp \
                         *.h \
                         *.cc \
                         *.md
RECURSIVE              = YES
EXCLUDE                =
EXCLUDE_SYMLINKS       = NO

OUTPUT_DIRECTORY       = @CMAKE_BINARY_DIR@/docs
GENERATE_HTML          = YES
GENERATE_XML           = YES
GENERATE_LATEX         = NO
GENERATE_MAN           = NO

XML_OUTPUT             = xml
HTML_OUTPUT            = html

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES

USE_MDFILE_AS_MAINPAGE = @CMAKE_SOURCE_DIR@/README.md

HAVE_DOT               = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES

JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = YES
MULTILINE_CPP_IS_BRIEF = NO
INHERIT_DOCS           = YES
SEPARATE_MEMBER_PAGES  = NO

TAB_SIZE               = 4
OPTIMIZE_OUTPUT_FOR_C  = NO
OPTIMIZE_OUTPUT_JAVA   = NO
OPTIMIZE_FOR_FORTRAN   = NO
OPTIMIZE_OUTPUT_VHDL   = NO

FULL_PATH_NAMES        = YES
STRIP_FROM_PATH        = @CMAKE_SOURCE_DIR@

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

SEARCHENGINE           = YES

QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO
