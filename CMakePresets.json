{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 31,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "default",
            "displayName": "Default (Debug)",
            "description": "Default build using Ninja with the Debug configuration.",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "release",
            "displayName": "Release",
            "description": "Optimized release build using Ninja.",
            "inherits": "default",
            "binaryDir": "${sourceDir}/build-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "debug",
            "displayName": "Debug (verbose)",
            "description": "Verbose debug build using Ninja.",
            "inherits": "default",
            "binaryDir": "${sourceDir}/build-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_VERBOSE_MAKEFILE": "ON"
            }
        },
        {
            "name": "asan",
            "displayName": "AddressSanitizer",
            "description": "Debug build with AddressSanitizer enabled.",
            "inherits": "default",
            "binaryDir": "${sourceDir}/build-asan",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_FLAGS": "-fsanitize=address -fno-omit-frame-pointer",
                "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address"
            }
        },
        {
            "name": "tsan",
            "displayName": "ThreadSanitizer",
            "description": "Debug build with ThreadSanitizer enabled.",
            "inherits": "default",
            "binaryDir": "${sourceDir}/build-tsan",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_FLAGS": "-fsanitize=thread -fno-omit-frame-pointer",
                "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=thread"
            }
        },
        {
            "name": "ubsan",
            "displayName": "UndefinedBehaviorSanitizer",
            "description": "Debug build with UndefinedBehaviorSanitizer enabled.",
            "inherits": "default",
            "binaryDir": "${sourceDir}/build-ubsan",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_FLAGS": "-fsanitize=undefined -fno-omit-frame-pointer",
                "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=undefined"
            }
        },
        {
            "name": "coverage",
            "displayName": "Coverage",
            "description": "Debug build with code coverage instrumentation.",
            "inherits": "default",
            "binaryDir": "${sourceDir}/build-coverage",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_FLAGS": "--coverage -O0 -g",
                "CMAKE_EXE_LINKER_FLAGS": "--coverage"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "default",
            "displayName": "Build (default)",
            "configurePreset": "default"
        },
        {
            "name": "release",
            "displayName": "Build (release)",
            "configurePreset": "release"
        },
        {
            "name": "debug",
            "displayName": "Build (debug)",
            "configurePreset": "debug"
        },
        {
            "name": "asan",
            "displayName": "Build (asan)",
            "configurePreset": "asan"
        },
        {
            "name": "tsan",
            "displayName": "Build (tsan)",
            "configurePreset": "tsan"
        },
        {
            "name": "ubsan",
            "displayName": "Build (ubsan)",
            "configurePreset": "ubsan"
        },
        {
            "name": "coverage",
            "displayName": "Build (coverage)",
            "configurePreset": "coverage"
        }
    ],
    "testPresets": [
        {
            "name": "test",
            "displayName": "Run tests",
            "description": "Run the test suite using the default (Debug) configuration.",
            "configurePreset": "default",
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "noTestsAction": "error",
                "stopOnFailure": false
            }
        }
    ]
}
